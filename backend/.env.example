# ── Auth ─────────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=600

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE=postgresql://postgres:postgres@127.0.0.1:5433/chatpaper
# Set false in multi-worker production; run 'alembic upgrade head' as a dedicated pre-start step.
RUN_MIGRATIONS_ON_STARTUP=true

# ── LLM / Embeddings ─────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
LLM_SUMMARY_TEMPERATURE=0.1

# ── ChromaDB ─────────────────────────────────────────────────────────────────
# Local dev: localhost:8001 — Docker Compose overrides these to chromadb:8000 automatically.
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION_CHILD_CHUNKS=child_chunks
CHROMA_COLLECTION_SUMMARIES=document_summaries

# ── Celery + Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# Set true in multi-worker production; startup aborts if Redis is unreachable.
REQUIRE_REDIS=false
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Ingestion limits ──────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=200
MAX_PAGES_PER_DOC=500
PARENT_CHUNK_SIZE=1800
PARENT_CHUNK_OVERLAP=200
CHILD_CHUNK_SIZE=400
CHILD_CHUNK_OVERLAP=60
EMBEDDING_BATCH_SIZE=100


# ── Google OAuth (all four required together, or omit all to disable) ─────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
REDIRECT_URL=http://localhost:8000/api/auth/google-callback
FRONTEND_URL=http://localhost:5173

# ── Registration / Security ───────────────────────────────────────────────────
# Set false to close self-registration in production.
REGISTRATION_OPEN=true
# Set true in production so the sqladmin session cookie is HTTPS-only.
SESSION_HTTPS_ONLY=false
# Set true when running behind a reverse proxy (nginx, ALB) so rate limiting
# keys on the real client IP from X-Forwarded-For rather than the proxy IP.
TRUST_PROXY_HEADERS=false

# ── Admin panel ───────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme-in-production

# ── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost/

# ── Chat cache tuning ────────────────────────────────────────────────────────
CHAT_STREAM_TTL_SECONDS=300

#_________________________email credentials for reset pass_____________________________________________

EMAIL_TOKEN_TTL_IN_SECONDS=600
MAIL_USERNAME="example@gmail.com",
MAIL_PASSWORD="wcsv dsfs orga ixxg",
MAIL_FROM="example@gmail.com",
MAIL_PORT=587,
MAIL_SERVER="smtp.gmail.com",
MAIL_STARTTLS=True,
MAIL_SSL_TLS=False,
USE_CREDENTIALS=True,

#_______________________________Stripe payment gateway________________________________________________

STRIPE_PUBLISHABLE_KEY=""
STRIPE_SECRET_KEY=""
WEBHOOK_KEY=""

CREDIT_COST_FILE_UPLOAD: int = 50
CREDIT_COST_CHAT:int = 10

BASIC_PRODUCT_ID=""
BASIC_PRICE_ID=""

PRO_PRODUCT_ID=""
PRO_PRICE_ID=""

#___________________________ Hugging face model____________________________________-

HF_API_KEY=""
HF_CHAT_MODEL="Qwen/Qwen2.5-7B-Instruct"
HF_ROUTER_CHAT_URL="https://router.huggingface.co/v1/chat/completions"
HF_EMBEDDING_MODEL="BAAI/bge-small-en-v1.5"
EMBEDDING_DIMENSION=384

SELECT_MODEL=HF
