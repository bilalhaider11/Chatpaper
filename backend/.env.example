# ── Auth ─────────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=600

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE=postgresql://postgres:postgres@localhost:5432/chatbot

# ── LLM / Embeddings ─────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
LLM_SUMMARY_TEMPERATURE=0.1

# ── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION_CHILD_CHUNKS=child_chunks
CHROMA_COLLECTION_SUMMARIES=document_summaries

# ── Celery + Redis + RabbitMQ ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# ── Ingestion limits ──────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=200
MAX_PAGES_PER_DOC=500
PARENT_CHUNK_SIZE=1800
PARENT_CHUNK_OVERLAP=200
CHILD_CHUNK_SIZE=400
CHILD_CHUNK_OVERLAP=60
EMBEDDING_BATCH_SIZE=100

# ── Google OAuth ─────────────────────────────────────────────────────────────
# Redirect URI must match Google Cloud Console (Authorized redirect URIs).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FRONTEND_URL=http://localhost:5173
REDIRECT_URL=http://localhost:8000/api/auth

# ── Chat cache / persistence ─────────────────────────────────────────────────
CHAT_DATA_TTL_SECONDS=3600
CHAT_STREAM_TTL_SECONDS=3600
CHAT_FLUSH_INTERVAL_SECONDS=3600