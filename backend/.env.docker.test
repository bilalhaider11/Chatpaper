# Copy to backend/.env before: docker compose up --build
# cp backend/.env.docker.example backend/.env

# ── Auth ─────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=600
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# ── Database (docker compose service: db) ─────────────────────────────────────
DATABASE=postgresql://postgres:postgres@localhost:5432/chatbot

# ── LLM ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# ── Redis / RabbitMQ (compose services) ───────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# ── Chroma (NOT containerized — point at host or external instance) ───────────
CHROMA_HOST=host.docker.internal
CHROMA_PORT=8001

# ── Frontend / CORS (browser URLs) ──────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
REDIRECT_URL=http://localhost:8000/api/auth
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Google OAuth (optional) ───────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Uploads (volume mounted in compose) ───────────────────────────────────────
UPLOAD_DIR=/app/files
